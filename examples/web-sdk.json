{
  "privateInfo": [
    {
      "type": "local",
      "path": "./path-to/web-sdk",
      "additionalContext": "This is the source code for the Nutrient Web SDK"
    }
  ],
  "publicInfo": [
    {
      "type": "package",
      "name": "@nutrient-sdk/viewer",
      "installCommand": "npm i @nutrient-sdk/viewer",
      "language": "javascript/typescript"
    }
  ],
  "agents": {
    "generator": { "command": "claude" },
    "executor": {
      "command": "claude",
      "secret": { "value": "$ANTHROPIC_API_KEY" }
    },
    "judge": {
      "command": "claude",
      "secret": { "value": "$ANTHROPIC_API_KEY" }
    }
  },
  "targets": [
    {
      "name": "node-20",
      "image": "node:20-slim",
      "timeout": 1200
    }
  ],
  "sandbox": {
    "concurrency": 3,
    "defaultTimeout": 600
  }
}
