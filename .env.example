# Agentic Usability — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These are loaded automatically when running any command.
# Shell environment variables take precedence over .env values.

# Claude Code (Anthropic)
ANTHROPIC_API_KEY=

# Codex (OpenAI)
OPENAI_API_KEY=

# Gemini CLI (Google)
GOOGLE_API_KEY=

# ── 1Password support ──────────────────────────────────────────
# Instead of plain-text secrets, you can use 1Password references.
# These are resolved at startup via the `op` CLI (must be installed and signed in).
#
# ANTHROPIC_API_KEY=op://Engineering/Anthropic/api-key
# OPENAI_API_KEY=op://Shared/OpenAI/credential
# GOOGLE_API_KEY=op://Shared/Google AI/api-key
