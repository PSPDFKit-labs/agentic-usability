{
  "name": "agentic-usability",
  "version": "1.0.0",
  "type": "module",
  "description": "SDK Usability Benchmark CLI",
  "bin": {
    "agentic-usability": "dist/index.js"
  },
  "scripts": {
    "build": "npm run build:ui && npm run build:server",
    "build:ui": "npm run build --prefix ui",
    "build:server": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@alibaba-group/opensandbox": "^0.1.5",
    "archiver": "^7.0.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "open": "^11.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.14",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.23.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "vitest": "^4.1.4"
  }
}
